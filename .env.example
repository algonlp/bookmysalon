PORT=8002
APP_ENV=dev
LOG_LEVEL=info
PUBLIC_SUPPORT_COMPANY_NAME=Algonlp
PUBLIC_GOOGLE_CLIENT_ID=
# Also supported:
# GOOGLE_CLIENT_ID=
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=
# VITE_GOOGLE_CLIENT_ID=
CLIENT_PLATFORM_STORAGE=file
APP_TIMEZONE=UTC
DEFAULT_BUSINESS_CURRENCY_CODE=USD
DEFAULT_BUSINESS_CURRENCY_LOCALE=en-US
WAITLIST_OFFER_WINDOW_MINUTES=10
TRUST_PROXY=false
PUBLIC_BASE_URL=
# Set this in deployed environments so QR codes, waitlist links, and dashboard launch links use your real domain.
CORS_ALLOWED_ORIGINS=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Also supported as fallbacks:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
ENABLE_PUBLIC_CUSTOMER_LOOKUPS=true
PUBLIC_PROFILE_FIELD_PHONE_LABEL=Business phone number
PUBLIC_PROFILE_FIELD_PHONE_PLACEHOLDER=+1234567890
PUBLIC_BOOKING_LOCATION_LABEL=Service location
PUBLIC_BOOKING_LOCATION_OPTION_PHYSICAL=Visit the salon
PUBLIC_BOOKING_LOCATION_OPTION_MOBILE=Barber comes to my home
PUBLIC_BOOKING_LOCATION_OPTION_VIRTUAL=Online service
PUBLIC_BOOKING_ADDRESS_LABEL=Home address
PUBLIC_BOOKING_ADDRESS_PLACEHOLDER=Enter your home address
PUBLIC_BOOKING_ADDRESS_HELP=Add the address where you want to receive the service.
PUBLIC_BOOKING_ADDRESS_REQUIRED=Home address is required when you choose at-home service.
PUBLIC_BOOKING_PHONE_LABEL=Phone number
PUBLIC_BOOKING_PHONE_HELP=You and the business will receive SMS updates on this number.
PUBLIC_BOOKING_PHONE_COUNTRY_CODE_LABEL=Country code
PUBLIC_BOOKING_PHONE_COUNTRY_CODE=
PUBLIC_BOOKING_PHONE_NUMBER_PLACEHOLDER=Enter phone number
PUBLIC_HOME_SEARCH_RESULTS_LIMIT=3
PLATFORM_ADMIN_COOKIE_NAME=platform_admin_session
ADMIN_SESSION_TTL_DAYS=30
# ── Email OTP via Gmail SMTP (recommended) ────────────────────
# Step 1: Google Account → Security → enable 2-Step Verification
# Step 2: Google Account → Security → App Passwords → create one for "Mail"
# Step 3: paste that 16-character password as SMTP_PASS below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=
SMTP_FROM=QR Schedule <your@gmail.com>

# ── Email OTP via SendGrid (alternative) ─────────────────────
# Sign up at sendgrid.com → Settings → API Keys → Create Key (Mail Send permission)
SENDGRID_API_KEY=
# Must be a verified sender in SendGrid (Settings → Sender Authentication)
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ── SMS OTP (Twilio) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# Optional aliases also supported:
# TWILIO_SID=
# TWILIO_TOKEN=
# TWILIO_FROM=
# Copy these values directly from Stripe Dashboard > Developers > API keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Copy this separately from Stripe Dashboard > Developers > Webhooks.
STRIPE_WEBHOOK_SECRET=
# Charge Stripe in GBP while app prices stay in PKR.
STRIPE_CHARGE_CURRENCY_CODE=GBP
# GBP per 1 PKR. Keep this updated, for example 0.0028 means 1000 PKR charges about 2.80 GBP.
STRIPE_PKR_TO_GBP_RATE=
# Optional fallback only. Package/business currency is used first.
STRIPE_PACKAGE_PAYMENT_CURRENCY_CODE=
STRIPE_PACKAGE_PAYMENT_APPLICATION_FEE_CENTS=0
# Test keys only: allow package Checkout on the platform account without salon Connect onboarding.
STRIPE_ALLOW_PLATFORM_PACKAGE_PAYMENTS_IN_TEST_MODE=false
# Default country used when creating a salon's Stripe Connect account.
STRIPE_CONNECT_COUNTRY_CODE=GB
SALON_ADMIN_PHONE=
